# Unity .gitignore - 프로젝트 루트
# https://github.com/github/gitignore/blob/main/Unity.gitignore

.utmp/
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/
*.log

# Blender
*.blend1
*.blend1.meta

# MemoryCaptures
/[Mm]emoryCaptures/

# Recordings
/[Rr]ecordings/

# Jetbrains Rider
/[Aa]ssets/Plugins/Editor/JetBrains*
*.DotSettings.user
*.DotSettings

# Visual Studio
.vs/

# Gradle
.gradle/

# 자동 생성 솔루션/프로젝트 파일
ExportedObj/
.consulo/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity3D generated meta files
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity3D generated file on crash reports
sysinfo.txt

# Mono auto generated files
mono_crash.*

# Builds
*.apk
*.aab
*.unitypackage
*.unitypackage.meta
*.app

# Crashlytics
crashlytics-build.properties

# TestRunner
InitTestScene*.unity*

# Addressables
/ServerData
/[Aa]ssets/StreamingAssets/aa*
/[Aa]ssets/AddressableAssetsData/link.xml*
/[Aa]ssets/Addressables_Temp*
/[Aa]ssets/AddressableAssetsData/*/*.bin*

# Visual Scripting
/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db
/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db.meta
/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers
/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers.meta

# Auto-generated scenes by play mode tests
/[Aa]ssets/[Ii]nit[Tt]est[Ss]cene*.unity*

# ── 팀 협업 보완 항목 ──────────────────────────────────────
# ExportedProject 내 Unity 생성 폴더
ExportedProject/[Ll]ibrary/
ExportedProject/[Tt]emp/
ExportedProject/[Oo]bj/
ExportedProject/[Bb]uild/
ExportedProject/[Bb]uilds/
ExportedProject/[Ll]ogs/
ExportedProject/[Uu]ser[Ss]ettings/

# OS 생성 파일
.DS_Store
Thumbs.db
desktop.ini

# merge 충돌 백업 파일
*.orig

# IDE
.idea/
*.swp
*.swo
