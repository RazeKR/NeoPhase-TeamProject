# ============================================================
# Unity .gitattributes - Smart Merge (UnityYAMLMerge) 설정
# (ExportedProject 내 Unity 프로젝트 루트용)
# ============================================================

* text=auto eol=lf

# ── Unity YAML 파일 (Smart Merge 대상) ──────────────────────
*.unity        merge=unityyamlmerge eol=lf
*.prefab       merge=unityyamlmerge eol=lf
*.asset        merge=unityyamlmerge eol=lf
*.meta         merge=unityyamlmerge eol=lf
*.controller   merge=unityyamlmerge eol=lf
*.anim         merge=unityyamlmerge eol=lf
*.playable     merge=unityyamlmerge eol=lf
*.overrideController merge=unityyamlmerge eol=lf
*.physicsMaterial2D  merge=unityyamlmerge eol=lf
*.lighting     merge=unityyamlmerge eol=lf
*.mat          merge=unityyamlmerge eol=lf
*.renderTexture merge=unityyamlmerge eol=lf
*.fontsettings  merge=unityyamlmerge eol=lf

# ── 이진(Binary) 파일 ──────────────────────────────────────
*.png          binary
*.jpg          binary
*.jpeg         binary
*.gif          binary
*.bmp          binary
*.tga          binary
*.tif          binary
*.tiff         binary
*.psd          binary
*.exr          binary
*.hdr          binary
*.mp3          binary
*.wav          binary
*.ogg          binary
*.mp4          binary
*.mov          binary
*.fbx          binary
*.obj          binary
*.blend        binary
*.dll          binary
*.so           binary
*.dylib        binary
*.exe          binary
*.apk          binary
*.aab          binary
*.zip          binary
*.unitypackage binary
*.spriteAtlas  binary

# ── 텍스트 파일 ────────────────────────────────────────────
*.cs           text eol=lf
*.js           text eol=lf
*.json         text eol=lf
*.xml          text eol=lf
*.yaml         text eol=lf
*.yml          text eol=lf
*.txt          text eol=lf
*.md           text eol=lf
*.shader       text eol=lf
*.cginc        text eol=lf
*.hlsl         text eol=lf
*.compute      text eol=lf
*.inputactions text eol=lf
*.uss          text eol=lf
*.uxml         text eol=lf
*.asmdef       text eol=lf
*.asmref       text eol=lf
